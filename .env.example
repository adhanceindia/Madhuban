# Database
DATABASE_URI=

# Payload CMS
PAYLOAD_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
NEXT_PUBLIC_R2_PUBLIC_URL=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Resend (email)
RESEND_API_KEY=
ADMIN_EMAIL=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash QStash — signature verification for scheduled jobs
# Find these in the Upstash dashboard under QStash → API Keys
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Google
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# iCal export — secret token required on the public .ics feed (generate: openssl rand -base64 32)
# OTAs must append ?token=<value> when subscribing to /api/ical/export
ICAL_EXPORT_TOKEN=

# Encryption — AES-256-GCM key for stored gateway secrets, 32 raw bytes base64 (generate: openssl rand -base64 32)
ENCRYPTION_KEY=

# Sentry — error monitoring DSN (recommended; see SECURITY.md / Task 15)
SENTRY_DSN=
